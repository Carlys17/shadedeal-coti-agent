# ShadeDeal defaults to a safe local mock ledger so the demo runs without spending gas.
# Set COTI_MODE=mcp to plug a COTI MCP/SDK bridge into src/cotiAdapter.ts.
COTI_MODE=mock
PORT=8787

# Public address used by the demo UI. Do not commit real private keys.
BUYER_AGENT_ADDRESS=0x1111111111111111111111111111111111111111
SELLER_AGENT_ADDRESS=0x2222222222222222222222222222222222222222

# Optional deployed contract details after COTI deployment.
COTI_NETWORK=mainnet
COTI_DEAL_REGISTRY_ADDRESS=
COTI_DEAL_REGISTRY_TX=
