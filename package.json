{
  "name": "shadedeal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private agent-to-agent dealmaking on COTI: encrypted negotiation, autonomous agents, and on-chain deal registry.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "demo": "tsx src/demo.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && npm run test",
    "compile:contracts": "hardhat compile"
  },
  "keywords": ["coti", "agent", "privacy", "encrypted-messaging", "web4", "hackathon"],
  "author": "Carlys",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "viem": "^2.41.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "hardhat": "^3.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
